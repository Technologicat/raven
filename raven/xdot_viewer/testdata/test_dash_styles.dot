digraph dash_test {
    rankdir=LR;
    node [shape=ellipse, style=filled, fillcolor="#4488cc"];

    A -> B [label="solid (default)"];
    A -> C [label="dashed", style=dashed];
    A -> D [label="dotted", style=dotted];
    B -> C [label="solid"];
    C -> D [label="dashed", style=dashed];
    B -> D [label="dotted", style=dotted];

    // Second group — same styles, different topology
    E -> F [label="dashed 2", style=dashed];
    E -> G [label="dotted 2", style=dotted];
    F -> G [label="solid 2"];
}
